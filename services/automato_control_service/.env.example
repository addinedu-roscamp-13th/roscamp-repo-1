# ACS 순찰 노드 타이밍 튜닝값 (초 단위).
# 실제로 쓰려면 이 파일을 복사해서 .env 를 만든다:  cp .env.example .env
#   * .env 는 .gitignore 로 커밋 제외(환경별 로컬 파일). 이 템플릿만 커밋해 "조정 가능한 값"을 문서화.
#   * 여기 없거나 주석 처리한 항목은 patrol_config.py 의 기본값이 쓰인다.
#   * 셸 export 나 ROS launch 로 넣은 값이 .env 보다 우선한다.

# 액션 서버 접속 대기 / Goal 수락 대기 / 세그먼트 결과 대기
ACS_SERVER_WAIT_SEC=5.0
ACS_GOAL_ACCEPT_TIMEOUT_SEC=30.0
ACS_SEGMENT_TIMEOUT_SEC=420.0

# 통로 예약 대기(양보 전) / 예약 폴링 간격
ACS_RESERVE_WAIT_SEC=30.0
ACS_RESERVE_POLL_SEC=1.0

# 막힘/양보 통로 블랙리스트 유지 시간
ACS_BLOCK_TTL_SEC=30.0

# 예약 유지 하트비트 간격 / 엔진 예약 TTL(하트비트보다 커야 함)
ACS_HEARTBEAT_SEC=5.0
ACS_RESERVATION_TTL_SEC=15.0
