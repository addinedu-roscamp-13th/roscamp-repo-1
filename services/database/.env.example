# Automato DB 접속 정보 (템플릿)
# 사용법: 이 파일을 복사해 .env 로 만들고 실제 값을 채운다.
#   cp .env.example .env
# .env 는 .gitignore 로 커밋되지 않는다 (비밀번호 노출 방지).

# --- docker-compose 및 PostgreSQL 컨테이너용 ---
POSTGRES_DB=automato
POSTGRES_USER=automato
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Alembic / 애플리케이션(ACS)이 쓰는 SQLAlchemy 연결 URL ---
# psycopg(v3) 드라이버 사용:  postgresql+psycopg://user:pass@host:port/db
DATABASE_URL=postgresql+psycopg://automato:change-me@localhost:5432/automato
